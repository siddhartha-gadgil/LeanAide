  #check "source:"
  #check "{\"status\": \"resolved\","
  #check " \"proof\":"
  #check " {\"verification\":"
  #check "  {\"type\": \"proof\","
  #check "   \"proof_steps\":"
  #check "   [{\"type\": \"theorem\","
  #check "     \"text\":"
  #check "     \"Let N={v in VQ | normQ(v)=0}. The seminorm axioms imply N is a rational vector subspace.\","
  #check "     \"status\": \"resolved\","
  #check "     \"proof\":"
  #check "     {\"type\": \"proof\","
  #check "      \"proof_steps\":"
  #check "      [{\"variable_type\": \"Set VQ\","
  #check "        \"variable_name\": \"N\","
  #check "        \"type\": \"let_statement\","
  #check "        \"statement\": \"N = {v in VQ | normQ(v) = 0}\"},"
  #check "       {\"type\": \"assert_statement\","
  #check "        \"proof_method\":"
  #check
    "        \"By the seminorm axioms: normQ(0)=0, the triangle inequality gives closure under addition, and absolute homogeneity gives closure under rational scalar multiplication.\","
  #check "        \"deduced_from_theorem\":"
  #check "        [{\"name\": \"Null space of a seminorm\","
  #check "          \"description\":"
  #check
    "          \"Applied to normQ to show that the set of vectors with seminorm zero is closed under zero, addition, and rational scalar multiplication.\","
  #check "          \"claim\":"
  #check "          \"The kernel/null set of a seminorm on a vector space is a vector subspace.\"}],"
  #check "        \"deduced_from_claim\":"
  #check "        [\"normQ is a seminorm on the rational vector space VQ\"],"
  #check "        \"claim\": \"N is a rational vector subspace of VQ.\"}]},"
  #check "     \"name\": \"homogeneous_root_lemma_13_proof_root_null_subspace\","
  #check "     \"label\": \"homogeneous.root.lemma-13.proof.root.null-subspace\","
  #check "     \"id\": \"homogeneous.root.lemma-13.proof.root.null-subspace\","
  #check "     \"header\": \"Claim\","
  #check "     \"claim\": \"N is a rational vector subspace of VQ.\"},"
  #check "    {\"verification\":"
  #check "     {\"type\": \"proof\","
  #check "      \"proof_steps\":"
  #check "      [{\"type\": \"theorem\","
  #check "        \"text\": \"Define W:=VQ/N.\","
  #check "        \"status\": \"resolved\","
  #check "        \"proof\":"
  #check "        {\"type\": \"proof\","
  #check "         \"proof_steps\":"
  #check "         [{\"variable_type\": \"rational quotient vector space VQ/N\","
  #check "           \"variable_name\": \"W\","
  #check "           \"type\": \"let_statement\","
  #check "           \"statement\": \"Define W := VQ/N.\","
  #check "           \"deduced_from_theorem\":"
  #check "           [{\"name\": \"Quotient vector space construction\","
  #check "             \"description\":"
  #check "             \"Used to define W as the quotient of VQ by the subspace N.\","
  #check "             \"claim\":"
  #check
    "             \"If N is a subspace of a vector space VQ, then the quotient VQ/N is a quotient vector space.\"}],"
  #check "           \"deduced_from_claim\": [\"N is a rational vector subspace of VQ\"]},"
  #check "          {\"type\": \"assert_statement\","
  #check "           \"proof_method\": \"By the definition of W.\","
  #check "           \"claim\": \"W = VQ/N\"}]},"
  #check "        \"name\": \"homogeneous_root_lemma_13_proof_root_quotient_norm_define_w\","
  #check "        \"label\": \"homogeneous.root.lemma-13.proof.root.quotient-norm.define-W\","
  #check "        \"id\": \"homogeneous.root.lemma-13.proof.root.quotient-norm.define-W\","
  #check "        \"header\": \"Claim\","
  #check "        \"claim\": \"W = VQ/N\"},"
  #check "       {\"verification\":"
  #check "        {\"type\": \"proof\","
  #check "         \"proof_steps\":"
  #check "         [{\"type\": \"theorem\","
  #check "           \"text\":"
  #check "           \"Define the induced function on W by the value of normQ on representatives.\","
  #check "           \"status\": \"resolved\","
  #check "           \"proof\":"
  #check "           {\"type\": \"proof\","
  #check "            \"proof_steps\":"
  #check "            [{\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check
    "              \"By the definition of the induced function normW on the quotient W = VQ/N, evaluating normW on the coset represented by v gives normQ(v).\","
  #check "              \"claim\": \"For v in VQ, normW(v + N) = normQ(v).\"}]},"
  #check "           \"name\":"
  #check "           \"homogeneous_root_lemma_13_proof_root_quotient_norm_induced_norm_definition\","
  #check "           \"label\":"
  #check "           \"homogeneous.root.lemma-13.proof.root.quotient-norm.induced-norm.definition\","
  #check "           \"id\":"
  #check "           \"homogeneous.root.lemma-13.proof.root.quotient-norm.induced-norm.definition\","
  #check "           \"header\": \"Claim\","
  #check "           \"claim\": \"For v in VQ, normW(v + N) = normQ(v).\"},"
  #check "          {\"type\": \"theorem\","
  #check "           \"text\":"
  #check "           \"If two representatives differ by an element of N, their normQ-values are equal.\","
  #check "           \"status\": \"resolved\","
  #check "           \"proof\":"
  #check "           {\"type\": \"proof\","
  #check "            \"proof_steps\":"
  #check "            [{\"type\": \"assume_statement\", \"assumption\": \"v - w ∈ N\"},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check "              \"By the definition of N as the zero set of normQ.\","
  #check "              \"deduced_from_claim\": [\"N = {u in VQ | normQ(u)=0}\"],"
  #check "              \"claim\": \"normQ(v - w) = 0\"},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check "              \"Apply the seminorm triangle inequality to v = w + (v - w), then use normQ(v - w)=0.\","
  #check "              \"deduced_from_theorem\":"
  #check "              [{\"name\": \"Seminorm triangle inequality rearranged\","
  #check "                \"description\":"
  #check "                \"Apply the triangle inequality to x = y + (x - y).\","
  #check "                \"claim\": \"For a seminorm p, p(x) ≤ p(y) + p(x - y).\"}],"
  #check "              \"claim\": \"normQ(v) ≤ normQ(w)\"},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check
    "              \"Apply the seminorm triangle inequality to w = v + (w - v), and use normQ(w - v)=normQ(-(v - w))=normQ(v - w)=0.\","
  #check "              \"deduced_from_theorem\":"
  #check "              [{\"name\": \"Seminorm symmetry\","
  #check "                \"description\": \"Use homogeneity by scalar -1.\","
  #check "                \"claim\": \"For a seminorm p, p(x) = p(-x).\"},"
  #check "               {\"name\": \"Seminorm triangle inequality rearranged\","
  #check "                \"description\":"
  #check "                \"Apply the triangle inequality to x = y + (x - y).\","
  #check "                \"claim\": \"For a seminorm p, p(x) ≤ p(y) + p(x - y).\"}],"
  #check "              \"claim\": \"normQ(w) ≤ normQ(v)\"},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\": \"By antisymmetry of the two inequalities.\","
  #check "              \"deduced_from_theorem\":"
  #check "              [{\"name\": \"Antisymmetry of ≤\","
  #check "                \"description\": \"Apply antisymmetry on real numbers.\","
  #check "                \"claim\": \"If a ≤ b and b ≤ a, then a = b.\"}],"
  #check "              \"claim\": \"normQ(v) = normQ(w)\"}]},"
  #check "           \"name\":"
  #check "           \"homogeneous_root_lemma_13_proof_root_quotient_norm_induced_norm_well_defined\","
  #check "           \"label\":"
  #check "           \"homogeneous.root.lemma-13.proof.root.quotient-norm.induced-norm.well-defined\","
  #check "           \"id\":"
  #check "           \"homogeneous.root.lemma-13.proof.root.quotient-norm.induced-norm.well-defined\","
  #check "           \"header\": \"Claim\","
  #check "           \"claim\": \"If v - w ∈ N, then normQ(v) = normQ(w).\"},"
  #check "          {\"type\": \"theorem\","
  #check "           \"text\":"
  #check
    "           \"The induced function inherits homogeneity and the triangle inequality from the seminorm normQ.\","
  #check "           \"status\": \"resolved\","
  #check "           \"proof\":"
  #check "           {\"type\": \"proof\","
  #check "            \"proof_steps\":"
  #check "            [{\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check
    "              \"For any rational scalar and any quotient class v + N, rewrite normW of the scalar multiple using normW(v + N) = normQ(v), then apply homogeneity of the seminorm normQ.\","
  #check "              \"claim\":"
  #check "              \"For every q in ℚ and every x in W, normW(q * x) = |q| * normW(x)\"},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check
    "              \"For any quotient classes v + N and w + N, rewrite normW of their sum and each summand using normW(u + N) = normQ(u), then apply the triangle inequality for the seminorm normQ.\","
  #check "              \"claim\":"
  #check "              \"For every x y in W, normW(x + y) <= normW(x) + normW(y)\"},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check
    "              \"Combine the inherited homogeneity and triangle inequality with the quotient-induced norm function.\","
  #check "              \"deduced_from_theorem\":"
  #check "              [{\"name\": \"Seminorm characterization by axioms\","
  #check "                \"description\":"
  #check "                \"Used to conclude that normW is a seminorm after verifying the inherited seminorm axioms.\","
  #check "                \"claim\":"
  #check
    "                \"A nonnegative function on a vector space satisfying homogeneity and the triangle inequality is a seminorm.\"}],"
  #check "              \"claim\": \"normW is a seminorm on W.\"}]},"
  #check "           \"name\":"
  #check "           \"homogeneous_root_lemma_13_proof_root_quotient_norm_induced_norm_seminorm_axioms\","
  #check "           \"label\":"
  #check "           \"homogeneous.root.lemma-13.proof.root.quotient-norm.induced-norm.seminorm-axioms\","
  #check "           \"id\":"
  #check "           \"homogeneous.root.lemma-13.proof.root.quotient-norm.induced-norm.seminorm-axioms\","
  #check "           \"header\": \"Claim\","
  #check "           \"claim\": \"normW is a seminorm on W.\"},"
  #check "          {\"type\": \"theorem\","
  #check "           \"text\":"
  #check
    "           \"If the induced norm of a coset is zero, then its representative lies in N, so the coset is zero in W.\","
  #check "           \"status\": \"resolved\","
  #check "           \"proof\":"
  #check "           {\"type\": \"proof\","
  #check "            \"proof_steps\":"
  #check "            [{\"variable_type\": \"W\","
  #check "              \"variable_name\": \"x\","
  #check "              \"type\": \"assume_statement\","
  #check "              \"assumption\":"
  #check "              \"Let `x` be an arbitrary element of `W` and assume `normW(x)=0`.\"},"
  #check "             {\"variable_type\": \"VQ\","
  #check "              \"variable_name\": \"v\","
  #check "              \"type\": \"let_statement\","
  #check "              \"statement\": \"Choose `v : VQ` such that `x = v + N`.\","
  #check "              \"deduced_from_theorem\":"
  #check "              [{\"name\": \"surjectivity of the quotient map\","
  #check "                \"description\":"
  #check "                \"Used to choose a representative of the quotient element `x`.\","
  #check "                \"claim\":"
  #check
    "                \"Every element of a quotient vector space `VQ/N` can be represented as a coset `v + N` for some `v ∈ VQ`.\"}]},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check
    "              \"Rewrite `normW(x)=0` using `x = v + N` and the definition of the induced norm on the coset `v + N`.\","
  #check "              \"deduced_from_claim\":"
  #check "              [\"x = v + N\", \"normW(x)=0\", \"normW(v + N) = normQ(v)\"],"
  #check "              \"claim\": \"normQ(v)=0\"},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check "              \"By the definition of `N` as the set of vectors whose `normQ` is zero.\","
  #check "              \"claim\": \"v ∈ N\"},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check
    "              \"Since the representative `v` lies in `N`, its coset is the zero element of the quotient `W = VQ/N`; using `x = v + N`, this gives `x=0`.\","
  #check "              \"deduced_from_theorem\":"
  #check "              [{\"name\": \"zero coset criterion\","
  #check "                \"description\":"
  #check "                \"Applied to the representative `v` to identify `x` with zero in `W`.\","
  #check "                \"claim\":"
  #check
    "                \"In a quotient by a subspace `N`, the coset `v + N` is equal to the zero coset if and only if `v ∈ N`.\"}],"
  #check "              \"deduced_from_claim\": [\"x = v + N\"],"
  #check "              \"claim\": \"x = 0\"},"
  #check "             {\"type\": \"assert_statement\","
  #check "              \"proof_method\":"
  #check "              \"Generalize the preceding argument over the arbitrary element `x`.\","
