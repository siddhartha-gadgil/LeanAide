        "type": "theorem",
        "label": "thm:limit_two_x_at_three",
        "header": "Theorem",
        "name": "thm_limit_two_x_at_three",
        "claim": "The function f(x)=2x has limit 6 as x tends to 3.",
        "proof": {
          "type": "epsilon_delta_proof",
          "epsilon_var": "epsilon",
          "epsilon_positive": "epsilon > 0",
          "delta": "epsilon/2",
          "delta_positive_proof": {
            "type": "assert_statement",
            "claim": "delta > 0.",
            "proof_method": "direct proof",
            "id": "epsilon_delta_linear_limit.root.thm_limit_two_x_at_three.proof.root.delta_positive",
            "status": "resolved",
            "text": "Since epsilon > 0 and delta=epsilon/2, delta is positive."
          },
          "bound_claim": "If |x-3| < delta, then |2x-6| < epsilon.",
          "bound_proof": {
            "type": "proof",
            "proof_steps": [
              {
                "type": "theorem",
                "label": "epsilon_delta_linear_limit.root.thm_limit_two_x_at_three.proof.root.verify_bound",
                "header": "Claim",
                "name": "epsilon_delta_linear_limit_root_thm_limit_two_x_at_three_proof_root_verify_bound",
                "claim": "|2x-6| < epsilon.",
                "proof": {
                  "type": "proof",
                  "proof_steps": [
                    {
                      "type": "assert_statement",
                      "claim": "|2x-6| = 2|x-3|",
                      "proof_method": "calculation step",
                      "from": "|2x-6|",
                      "relation": "=",
                      "to": "2|x-3|"
                    },
                    {
                      "type": "assert_statement",
                      "claim": "2|x-3| < 2 delta",
                      "proof_method": "calculation step",
                      "from": "2|x-3|",
                      "relation": "<",
                      "to": "2 delta"
                    },
                    {
                      "type": "assert_statement",
                      "claim": "2 delta = epsilon",
                      "proof_method": "calculation step",
                      "from": "2 delta",
                      "relation": "=",
                      "to": "epsilon"
                    }
                  ]
                },
                "id": "epsilon_delta_linear_limit.root.thm_limit_two_x_at_three.proof.root.verify_bound",
                "status": "resolved",
                "text": "If |x-3|<delta, then |2x-6|=2|x-3|<2delta=epsilon."
              }
            ]
          },
          "id": "epsilon_delta_linear_limit.root.thm_limit_two_x_at_three.proof.root",
          "status": "resolved"
        },
        "source": {
          "text": "Theorem. The function f(x)=2x has limit 6 as x tends to 3.\n\nProof. Let epsilon>0 and choose delta=epsilon/2. Since epsilon is positive,\ndelta is positive. If |x-3|<delta, then |2x-6|=2|x-3|<2delta=epsilon.",
          "id": "epsilon_delta_linear_limit.root.thm_limit_two_x_at_three",
          "label": "thm:limit_two_x_at_three"
        },
