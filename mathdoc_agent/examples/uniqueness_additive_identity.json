        "label": "thm:unique_additive_identity",
        "header": "Theorem",
        "claim": "In an additive group, there is a unique additive identity.",
        "proof": {
          "type": "uniqueness_proof",
          "existence_proof": {
            "type": "existence_proof",
            "full_claim": "There exists an element e such that e is an additive identity.",
