                "type": "theorem",
                "label": "uniqueness_additive_identity.root.thm_unique_additive_identity.proof.root.uniqueness",
                "header": "Claim",
                "claim": "Any two additive identities are equal.",
                "proof": {
                  "type": "proof",
                  "proof_steps": [
                    {
