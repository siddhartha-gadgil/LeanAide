                      "id": "uniqueness_additive_identity.root.thm_unique_additive_identity.proof.root.uniqueness.step1",
                      "status": "resolved",
                      "text": "Suppose e and e' are both additive identities."
                    },
                    {
                      "type": "assert_statement",
                      "claim": "Since e is an identity, e+e'=e'.",
                      "proof_method": "direct proof",
                      "id": "uniqueness_additive_identity.root.thm_unique_additive_identity.proof.root.uniqueness.step2",
                      "status": "resolved",
                      "text": "Since e is an identity, e+e'=e'."
                    },
                    {
                      "type": "assert_statement",
                      "claim": "Since e' is an identity, e+e'=e.",
                      "proof_method": "direct proof",
                      "id": "uniqueness_additive_identity.root.thm_unique_additive_identity.proof.root.uniqueness.step3",
                      "status": "resolved",
                      "text": "Since e' is an identity, e+e'=e."
                    },
                    {
                      "type": "assert_statement",
                      "claim": "Hence e=e'.",
                      "proof_method": "direct proof",
                      "id": "uniqueness_additive_identity.root.thm_unique_additive_identity.proof.root.uniqueness.step4",
                      "status": "resolved",
                      "text": "Hence e=e'."
                    }
                  ]
                },
                "id": "uniqueness_additive_identity.root.thm_unique_additive_identity.proof.root.uniqueness",
                "status": "resolved",
                "text": "Suppose e and e' are both additive identities. Since e is an identity, e+e'=e'. Since e' is an identity, e+e'=e. Hence e=e'."
