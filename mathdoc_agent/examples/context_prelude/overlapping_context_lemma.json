    "title": "Overlapping Local Context Lemma",
    "body": [
      {
        "type": "theorem",
        "label": "Theorem 1",
        "header": "Theorem",
        "name": "zero_at_one_from_zero_everywhere",
        "hypothesis": [
          {
            "type": "assume_statement",
            "assumption": "G is a group."
          },
          {
            "type": "let_statement",
            "variable_name": "l",
            "variable_type": "G -> R",
            "statement": "Let l : G -> R."
          },
          {
            "type": "assume_statement",
            "assumption": "For every g in G, l(g)=0."
          }
        ],
        "claim": "l(1)=0.",
        "source": {
          "text": "Let \\(G\\) be a group and let \\(l : G \\to \\mathbb{R}\\). Assume that \\(l(g)=0\\) for every \\(g\\in G\\). Then \\(l(1)=0\\).",
          "id": "overlapping_context_lemma.root.theorem-1",
          "label": "Theorem 1"
        },
        "proof": {
          "type": "proof",
          "proof_steps": [
            {
              "type": "theorem",
              "label": "Auxiliary Lemma",
              "header": "Lemma",
              "name": "zero_on_all_elements",
              "claim": "For every x in G, l(x)=0.",
              "source": {
                "text": "We first prove the auxiliary lemma that, for every \\(x\\in G\\), \\(l(x)=0\\). This lemma uses the same \\(G\\), group structure, \\(l\\), and \\(h_0\\) already fixed in the theorem context.",
                "id": "overlapping_context_lemma.root.theorem-1.proof.lemma-zero-on-all",
                "label": "Auxiliary Lemma"
              },
              "proof": {
                "type": "proof",
                "proof_steps": [
                  {
                    "type": "assert_statement",
                    "claim": "l(x)=0 for an arbitrary x in G.",
                    "proof_method": "Apply the assumption that l(g)=0 for every g in G to x.",
                    "id": "overlapping_context_lemma.root.theorem-1.proof.lemma-zero-on-all.proof.step-1",
                    "status": "resolved"
                  }
                ],
                "id": "overlapping_context_lemma.root.theorem-1.proof.lemma-zero-on-all.proof",
