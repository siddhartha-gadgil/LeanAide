{
  "document": {
    "type": "document",
    "body": [
      {
        "type": "theorem",
        "label": "source_id.root.theorem",
        "header": "Theorem",
        "claim": "Let $(X, d)$ be a metric space. Let $x$ and $y$ be two distinct points with distance $d(x, y) = \\epsilon > 0$. Then the open balls $B(x, \\epsilon/3)$ and $B(y, \\epsilon/3)$ do not intersect.",
        "proof": {
          "type": "contradiction_statement",
          "assumption": "\\(B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)\\neq\\varnothing\\), equivalently there exists \\(z\\in X\\) lying in both balls.",
          "proof": {
            "type": "proof",
            "proof_steps": [
              {
                "type": "let_statement",
                "variable_name": "z",
                "statement": "Let z be a point in \\(B(x,\\varepsilon/3)\\cap B(y,\\varepsilon/3)\\)."
              },
              {
                "type": "assert_statement",
                "claim": "z lies in both balls: \\(z\\in B(x,\\varepsilon/3)\\) and \\(z\\in B(y,\\varepsilon/3)\\).",
                "proof_method": "By the assumption that z lies in the intersection."
              },
              {
                "type": "assert_statement",
                "claim": "\\(d(z,x)<\\varepsilon/3\\) and \\(d(z,y)<\\varepsilon/3\\).",
                "proof_method": "By the definition of open ball."
              },
              {
                "type": "assert_statement",
                "claim": "\\(d(x,z)<\\varepsilon/3\\).",
                "proof_method": "By symmetry of the metric and \\(d(z,x)<\\varepsilon/3\\)."
              },
              {
                "type": "theorem",
                "label": "source_id.root.theorem.proof.root.triangle_inequality_contradiction",
                "header": "Claim",
                "claim": "1 < 2/3",
                "proof": {
                  "type": "proof",
                  "calculation_kind": "calculation_to_contradiction",
                  "start": "d(x,y)",
                  "target": "1 < 2/3",
                  "goal_relation": "mixed",
                  "proof_steps": [
                    {
                      "type": "assert_statement",
                      "claim": "d(x,y) ≤ d(x,z) + d(z,y)",
                      "proof_method": "triangle inequality",
                      "from": "d(x,y)",
                      "relation": "≤",
                      "to": "d(x,z) + d(z,y)"
                    },
                    {
                      "type": "assert_statement",
                      "claim": "d(x,z) + d(z,y) < \\varepsilon/3 + \\varepsilon/3",
                      "proof_method": "using \\(d(x,z)<\\varepsilon/3\\) and \\(d(z,y)<\\varepsilon/3\\)",
                      "from": "d(x,z) + d(z,y)",
                      "relation": "<",
                      "to": "\\varepsilon/3 + \\varepsilon/3"
                    },
                    {
                      "type": "assert_statement",
                      "claim": "\\varepsilon/3 + \\varepsilon/3 = 2\\varepsilon/3",
                      "proof_method": "arithmetic normalization",
                      "from": "\\varepsilon/3 + \\varepsilon/3",
                      "relation": "=",
                      "to": "2\\varepsilon/3"
                    },
                    {
                      "type": "assert_statement",
                      "claim": "\\varepsilon < 2\\varepsilon/3",
                      "proof_method": "substitute \\(d(x,y)=\\varepsilon\\)",
                      "from": "\\varepsilon",
                      "relation": "<",
                      "to": "2\\varepsilon/3"
                    },
                    {
                      "type": "assert_statement",
                      "claim": "1 < 2/3",
                      "proof_method": "divide by the positive number \\(\\varepsilon\\)",
                      "from": "1",
                      "relation": "<",
                      "to": "2/3"
                    }
                  ]
                },
                "id": "source_id.root.theorem.proof.root.triangle_inequality_contradiction",
                "status": "resolved"
              },
              {
                "type": "assert_statement",
                "claim": "The inequality \\(1<2/3\\) is impossible.",
                "proof_method": "By arithmetic order on real numbers."
              }
            ]
          },
          "id": "source_id.root.theorem.proof.root",
          "status": "resolved"
        },
        "id": "source_id.root.theorem",
        "status": "resolved"
      }
    ],
    "title": "Metric Space Proof"
  }
}
